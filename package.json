{
  "name": "tarok",
  "version": "1.5.2",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "electron:dev": "npm run build && electron .",
    "electron:build": "npm run build && electron-builder --win --config.directories.output=C:\\TarokBuild",
    "electron:build:mac": "npm run build && electron-builder --mac --config.directories.output=release",
    "deploy": "wrangler pages deploy"
  },
  "type": "module",
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.9",
    "electron": "^42.5.0",
    "electron-builder": "^26.15.3",
    "jsdom": "^29.1.1",
    "playwright": "^1.61.0",
    "png-to-ico": "^3.0.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.9",
    "wrangler": "^4.112.0"
  },
  "build": {
    "appId": "com.tarok.app",
    "productName": "Tarok",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**",
      "electron/main.cjs"
    ],
    "icon": "public/favicon.ico",
    "win": {
      "target": "nsis",
      "icon": "public/favicon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "public/favicon.png",
      "category": "public.app-category.games"
    },
    "nsis": {
      "oneClick": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
